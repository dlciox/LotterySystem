<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LotterySystem.Views.ClassEditPage"
             Title="Edycja klasy">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <Label Text="Dodaj ucznia:" />
            <Entry x:Name="FirstNameEntry" Placeholder="Imię" />
            <Entry x:Name="LastNameEntry" Placeholder="Nazwisko" />
            <Button Text="Dodaj ucznia" Clicked="AddStudent" />

            <BoxView HeightRequest="1" />

            <Label Text="Lista uczniów:" />

            <CollectionView x:Name="StudentsListView" 
                            ItemsSource="{Binding Students}"
                            SelectionMode="Single"
                            SelectionChanged="SelectStudent"
                            HeightRequest="300">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="10" Margin="0,2" BorderColor="LightGray" CornerRadius="5">
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="{Binding Number}" VerticalOptions="Center" />
                                <Label Text="." VerticalOptions="Center" />
                                <Label Text="{Binding LastName}" VerticalOptions="Center" />
                                <Label Text="{Binding FirstName}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Edytuj wybranego" Clicked="EditStudent" />
            <Button Text="Usuń wybranego" Clicked="RemoveStudent" />
            <Button Text="Zapisz do pliku" Clicked="SaveClassToFile" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>