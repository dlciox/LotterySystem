<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LotterySystem.Views.MainPage"
             Title="System losowania">
    <VerticalStackLayout Padding="20" Spacing="10">
        
        <Label Text="Nowa klasa:" />
        <Entry x:Name="NewClassEntry" Placeholder="Nazwa klasy" />
        <Button Text="Utwórz klasę" Clicked="CreateClass" />

        <BoxView HeightRequest="1" Color="Gray" />

        <Label Text="Wybierz klasę:" />
        <Picker x:Name="ClassPicker" />

        <Button Text="Edytuj klasę" Clicked="OpenClassEditor" />
        <Button Text="Losuj ucznia" Clicked="OpenLotteryPage" />
    </VerticalStackLayout>
</ContentPage>